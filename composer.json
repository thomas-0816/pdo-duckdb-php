{
    "name": "thomas-0816/pdo-duckdb-php",
    "type": "php-ext",
    "license": "MIT",
    "description": "PHP PDO DuckDB",
    "require": {
        "php": ">=8.2"
    },
    "php-ext": {
        "extension-name": "pdo_duckdb",
        "download-url-method": ["pre-packaged-binary", "composer-default"],
        "priority": 74,
        "configure-options": [
            {
                "name": "with-pdo-duckdb",
                "needs-value": false,
                "description": "whether to enable pdo_duckdb support"
            }
        ]
    }
}
